{
  "@context": "https://www.w3.org/ns/dcat.jsonld",
  "@type": "dcat:Dataset",
  "dct:title": "Packrift SKU Evidence Cards",
  "dct:description": "Public Packrift SKU evidence cards and data files.",
  "dcat:landingPage": "https://packrift-sku-evidence-cards.vercel.app",
  "dcat:distribution": [
    {
      "@type": "dcat:Distribution",
      "dcat:downloadURL": "https://packrift-sku-evidence-cards.vercel.app/data/products.csv",
      "dct:format": "text/csv"
    },
    {
      "@type": "dcat:Distribution",
      "dcat:downloadURL": "https://packrift-sku-evidence-cards.vercel.app/data/products.json",
      "dct:format": "application/json"
    }
  ]
}

{
  "openapi": "3.1.0",
  "info": {
    "title": "Packrift Weight Density Atlas",
    "version": "1.0.0",
    "description": "Static public Packrift weight-density reference files."
  },
  "servers": [
    {
      "url": "https://packrift.github.io/weight-density-atlas"
    }
  ],
  "paths": {
    "/data/stats.json": {
      "get": {
        "summary": "Read atlas stats",
        "responses": {
          "200": {
            "description": "Stats JSON"
          }
        }
      }
    },
    "/data/weight-density.jsonl": {
      "get": {
        "summary": "Read all weight-density records",
        "responses": {
          "200": {
            "description": "JSONL records"
          }
        }
      }
    },
    "/sitemap.xml": {
      "get": {
        "summary": "Read sitemap",
        "responses": {
          "200": {
            "description": "Sitemap XML"
          }
        }
      }
    }
  }
}